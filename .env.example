# AceleraBot API — Variáveis de Ambiente
# Copie para .env (local) ou configure no painel do Render (produção).

# ─── App (.NET / ASP.NET Core) ───────────────────────────────
PORT=3000
# Modo simulado: 'true' faz Gemini, WhatsApp e Google Calendar responderem
# com dados fake (útil para rodar sem credenciais reais).
MOCK_MODE=false

# ─── Banco (Supabase Postgres via EF Core / Npgsql) ──────────
# Em produção use o Session Pooler do Supabase (IPv4):
#   Host=aws-0-<region>.pooler.supabase.com;Port=5432;Username=postgres.<ref>;Password=<senha>;Database=postgres;SSL Mode=Require;Trust Server Certificate=true
ConnectionStrings__Default=Host=db.xxxxxxxxxxxx.supabase.co;Port=5432;Username=postgres;Password=<senha>;Database=postgres;SSL Mode=Require;Trust Server Certificate=true

# ─── Google Gemini ───────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ─── Evolution API (WhatsApp) ────────────────────────────────
EVOLUTION_API_URL=https://acelera-evolution-api.onrender.com
EVOLUTION_API_KEY=sua_chave_secreta_aqui

# ─── Redis / Upstash ─────────────────────────────────────────
# Use a URI no formato rediss://default:<senha>@<host>:6379
REDIS_URL=rediss://default:senha@host.upstash.io:6379

# ─── URLs de integração ──────────────────────────────────────
# URL pública do dashboard (frontend Vercel) — usada no CORS e no OAuth.
DASHBOARD_URL=http://localhost:3001
# URL pública deste backend — usada para registrar webhooks na Evolution.
APP_URL=http://localhost:3000

# ─── Google Calendar (OAuth) ─────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Deve casar com a Authorized redirect URI no Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3000/google/callback

# ─── Notificações ────────────────────────────────────────────
# Número do WhatsApp do DONO DA PLATAFORMA (você), formato 55DDDNUMERO.
PLATFORM_OWNER_WHATSAPP=5511999999999
